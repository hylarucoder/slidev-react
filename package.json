{
  "name": "slidev-react",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Open-source React + MDX presentation app/runtime (not published to npm)",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.3",
  "scripts": {
    "clean": "rm -rf dist .generated output",
    "dev": "rsbuild dev",
    "build": "rsbuild build",
    "make": "bun run build",
    "preview": "rsbuild preview",
    "presentation:server": "bun ./scripts/presentation-server.ts",
    "test": "vitest --run",
    "lint": "oxlint src"
  },
  "dependencies": {
    "@mdx-js/mdx": "3.1.1",
    "@mdx-js/react": "3.1.1",
    "katex": "0.16.33",
    "lucide-react": "0.568.0",
    "mermaid": "11.12.3",
    "plantuml-encoder": "1.4.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "rehype-katex": "7.0.1",
    "remark-gfm": "4.0.1",
    "remark-math": "6.0.0",
    "rough-notation": "^0.5.1",
    "shiki": "4.0.1",
    "shiki-magic-move": "1.2.1",
    "yaml": "2.8.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@rsbuild/core": "^1.7.3",
    "@rsbuild/plugin-react": "^1.4.5",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "oxlint": "1.50.0",
    "postcss": "^8.5.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vitest": "4.0.9"
  }
}
